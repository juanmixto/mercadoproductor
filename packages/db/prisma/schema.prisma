// Mercado Productor — Prisma Schema
// PostgreSQL + multi-vendor marketplace

generator client {
  provider = "prisma-client-js"
  output   = "../generated/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────────────────────
// USERS & AUTH
// ─────────────────────────────────────────────────────────────────────────────

enum UserRole {
  CUSTOMER
  VENDOR
  ADMIN_SUPPORT
  ADMIN_CATALOG
  ADMIN_FINANCE
  ADMIN_OPS
  SUPERADMIN
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  passwordHash  String
  firstName     String
  lastName      String
  phone         String?
  role          UserRole  @default(CUSTOMER)
  isActive      Boolean   @default(true)
  emailVerified Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  vendor          Vendor?
  orders          Order[]
  cart            Cart?
  incidentsOpened Incident[] @relation("CustomerIncidents")
  adminEvents     OrderEvent[] @relation("AdminEvents")
  addresses       CustomerAddress[]
  sessions        UserSession[]

  @@index([email])
  @@map("users")
}

model UserSession {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
  @@map("user_sessions")
}

model CustomerAddress {
  id         String  @id @default(cuid())
  userId     String
  label      String?
  isDefault  Boolean @default(false)
  name       String
  line1      String
  line2      String?
  city       String
  province   String
  postalCode String
  country    String  @default("ES")
  phone      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("customer_addresses")
}

// ─────────────────────────────────────────────────────────────────────────────
// VENDORS (PRODUCTORES)
// ─────────────────────────────────────────────────────────────────────────────

enum VendorStatus {
  APPLYING
  PENDING_DOCS
  ACTIVE
  SUSPENDED_TEMP
  REJECTED
  DEACTIVATED
}

model Vendor {
  id                String       @id @default(cuid())
  userId            String       @unique
  slug              String       @unique
  displayName       String
  description       String?
  logoUrl           String?
  bannerUrl         String?
  location          String?
  originRegion      String?
  website           String?
  status            VendorStatus @default(APPLYING)
  taxId             String?
  iban              String?
  bankAccountName   String?
  commissionRate    Decimal?     @db.Decimal(5, 4)
  orderCutoffDays   String[]     // ["MON","WED","FRI"]
  orderCutoffTime   String?      // "12:00"
  preparationDays   Int          @default(1)
  shippingZones     Json?        // { zones: [...], rates: [...] }
  rejectionReason   String?
  warningCount      Int          @default(0)
  cancellationRate  Decimal      @default(0) @db.Decimal(5, 4)
  avgRating         Decimal      @default(0) @db.Decimal(3, 2)
  totalReviews      Int          @default(0)
  activatedAt       DateTime?
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  user              User               @relation(fields: [userId], references: [id])
  products          Product[]
  fulfillments      VendorFulfillment[]
  settlements       Settlement[]
  commissionRules   CommissionRule[]
  incidentsReceived Incident[]         @relation("VendorIncidents")
  vendorEvents      VendorEvent[]

  @@index([slug])
  @@index([status])
  @@map("vendors")
}

model VendorEvent {
  id          String   @id @default(cuid())
  vendorId    String
  eventType   String
  triggeredBy String
  metadata    Json?
  createdAt   DateTime @default(now())

  vendor Vendor @relation(fields: [vendorId], references: [id])

  @@index([vendorId])
  @@map("vendor_events")
}

// ─────────────────────────────────────────────────────────────────────────────
// CATALOG
// ─────────────────────────────────────────────────────────────────────────────

model Category {
  id          String     @id @default(cuid())
  parentId    String?
  slug        String     @unique
  name        String
  description String?
  imageUrl    String?
  position    Int        @default(0)
  isActive    Boolean    @default(true)
  createdAt   DateTime   @default(now())

  parent      Category?  @relation("CategoryTree", fields: [parentId], references: [id])
  children    Category[] @relation("CategoryTree")
  products    Product[]

  @@index([parentId])
  @@map("categories")
}

enum ProductStatus {
  DRAFT
  PENDING_REVIEW
  ACTIVE
  SUSPENDED
  DISCONTINUED
  REJECTED
}

model Product {
  id               String        @id @default(cuid())
  vendorId         String
  categoryId       String
  slug             String        @unique
  name             String
  description      String        @db.Text
  images           String[]
  status           ProductStatus @default(DRAFT)
  basePrice        Decimal       @db.Decimal(10, 2)
  compareAtPrice   Decimal?      @db.Decimal(10, 2)
  taxRate          Decimal       @default(0.10) @db.Decimal(4, 3)
  unit             String        @default("ud")
  minOrderQuantity Int           @default(1)
  maxOrderQuantity Int?
  stock            Int           @default(0)
  lowStockAlert    Int           @default(5)
  weight           Decimal?      @db.Decimal(8, 3)
  tags             String[]
  certifications   String[]
  originRegion     String?
  rejectionReason  String?
  reviewNote       String?
  lastPriceChange  DateTime?
  previousPrice    Decimal?      @db.Decimal(10, 2)
  isDigital        Boolean       @default(false)
  publishedAt      DateTime?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  vendor    Vendor           @relation(fields: [vendorId], references: [id])
  category  Category         @relation(fields: [categoryId], references: [id])
  variants  ProductVariant[]
  cartItems CartItem[]
  orderLines OrderLine[]

  @@index([vendorId])
  @@index([categoryId])
  @@index([status])
  @@index([slug])
  @@map("products")
}

model ProductVariant {
  id         String   @id @default(cuid())
  productId  String
  sku        String   @unique
  name       String
  price      Decimal  @db.Decimal(10, 2)
  stock      Int      @default(0)
  weight     Decimal? @db.Decimal(8, 3)
  attributes Json     // {"size": "L", "color": "red"}
  imageUrl   String?
  isActive   Boolean  @default(true)
  position   Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  product    Product    @relation(fields: [productId], references: [id], onDelete: Cascade)
  cartItems  CartItem[]
  orderLines OrderLine[]

  @@index([productId])
  @@index([sku])
  @@map("product_variants")
}

// ─────────────────────────────────────────────────────────────────────────────
// CART
// ─────────────────────────────────────────────────────────────────────────────

enum CartStatus {
  ACTIVE
  ABANDONED
  CONVERTED
}

model Cart {
  id         String     @id @default(cuid())
  customerId String?    @unique
  sessionId  String     @unique
  status     CartStatus @default(ACTIVE)
  currency   String     @default("EUR")
  couponCode String?
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  expiresAt  DateTime

  customer User?      @relation(fields: [customerId], references: [id])
  items    CartItem[]

  @@index([sessionId])
  @@index([customerId])
  @@map("carts")
}

model CartItem {
  id               String   @id @default(cuid())
  cartId           String
  productId        String
  variantId        String?
  vendorId         String
  quantity         Int
  unitPrice        Decimal  @db.Decimal(10, 2)
  priceSnapshot    Json     // { name, imageUrl, vendorName, price, capturedAt }
  fulfillmentGroup String
  isAvailable      Boolean  @default(true)
  priceChanged     Boolean  @default(false)
  metadata         Json?
  addedAt          DateTime @default(now())
  updatedAt        DateTime @updatedAt

  cart    Cart            @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product Product         @relation(fields: [productId], references: [id])
  variant ProductVariant? @relation(fields: [variantId], references: [id])

  @@unique([cartId, productId, variantId])
  @@index([cartId])
  @@map("cart_items")
}

// ─────────────────────────────────────────────────────────────────────────────
// ORDERS
// ─────────────────────────────────────────────────────────────────────────────

enum OrderStatus {
  PLACED
  PAYMENT_PENDING
  PAYMENT_FAILED
  PAYMENT_CONFIRMED
  PROCESSING
  PARTIALLY_READY
  READY_TO_SHIP
  PARTIALLY_SHIPPED
  SHIPPED
  PARTIALLY_DELIVERED
  DELIVERED
  COMPLETED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  PROCESSING
  SUCCEEDED
  FAILED
  REFUNDED
  PARTIALLY_REFUNDED
}

model Order {
  id                String        @id @default(cuid())
  orderNumber       String        @unique // ORD-2026-00412
  customerId        String
  status            OrderStatus   @default(PLACED)
  shippingAddress   Json          // Address snapshot
  billingAddress    Json          // Address snapshot
  paymentIntentId   String?
  paymentStatus     PaymentStatus @default(PENDING)
  currency          String        @default("EUR")
  subtotal          Decimal       @db.Decimal(10, 2)
  shippingTotal     Decimal       @db.Decimal(10, 2) @default(0)
  discountTotal     Decimal       @db.Decimal(10, 2) @default(0)
  taxTotal          Decimal       @db.Decimal(10, 2)
  grandTotal        Decimal       @db.Decimal(10, 2)
  couponCode        String?
  notesFromCustomer String?
  cancelReason      String?
  placedAt          DateTime      @default(now())
  confirmedAt       DateTime?
  fulfilledAt       DateTime?
  closedAt          DateTime?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  customer     User               @relation(fields: [customerId], references: [id])
  lines        OrderLine[]
  fulfillments VendorFulfillment[]
  events       OrderEvent[]
  incidents    Incident[]

  @@index([customerId])
  @@index([status])
  @@index([orderNumber])
  @@map("orders")
}

enum OrderLineStatus {
  PENDING_VENDOR_CONFIRMATION
  CONFIRMED
  PREPARING
  SHIPPED
  DELIVERED
  COMPLETED
  CANCELLED_BY_VENDOR
  CANCELLED_BY_ADMIN
  CANCELLED_BY_CUSTOMER
}

model OrderLine {
  id              String          @id @default(cuid())
  orderId         String
  vendorId        String
  productId       String
  variantId       String?
  productSnapshot Json            // { name, imageUrl, vendorName, sku, description }
  quantity        Int
  unitPrice       Decimal         @db.Decimal(10, 2)
  lineTotal       Decimal         @db.Decimal(10, 2)
  taxRate         Decimal         @db.Decimal(4, 3)
  taxAmount       Decimal         @db.Decimal(10, 2)
  status          OrderLineStatus @default(PENDING_VENDOR_CONFIRMATION)
  fulfillmentId   String?
  cancelReason    String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  order       Order             @relation(fields: [orderId], references: [id])
  product     Product           @relation(fields: [productId], references: [id])
  variant     ProductVariant?   @relation(fields: [variantId], references: [id])
  fulfillment VendorFulfillment? @relation(fields: [fulfillmentId], references: [id])
  incidents   Incident[]
  settlementLines SettlementLine[]

  @@index([orderId])
  @@index([vendorId])
  @@index([productId])
  @@map("order_lines")
}

enum FulfillmentStatus {
  PENDING
  CONFIRMED
  PREPARING
  READY
  SHIPPED
  DELIVERED
  FAILED
}

model VendorFulfillment {
  id             String            @id @default(cuid())
  orderId        String
  vendorId       String
  status         FulfillmentStatus @default(PENDING)
  trackingNumber String?
  carrier        String?
  vendorNotes    String?
  shippedAt      DateTime?
  deliveredAt    DateTime?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  order  Order       @relation(fields: [orderId], references: [id])
  vendor Vendor      @relation(fields: [vendorId], references: [id])
  lines  OrderLine[]

  @@index([orderId])
  @@index([vendorId])
  @@map("vendor_fulfillments")
}

model OrderEvent {
  id          String   @id @default(cuid())
  orderId     String
  eventType   String
  triggeredBy String   // customer | vendor | admin | system
  adminId     String?
  metadata    Json?
  createdAt   DateTime @default(now())

  order Order  @relation(fields: [orderId], references: [id])
  admin User?  @relation("AdminEvents", fields: [adminId], references: [id])

  @@index([orderId])
  @@map("order_events")
}

// ─────────────────────────────────────────────────────────────────────────────
// COMMISSIONS & SETTLEMENTS
// ─────────────────────────────────────────────────────────────────────────────

enum CommissionType {
  PERCENTAGE
  FIXED
  TIERED
}

model CommissionRule {
  id                String         @id @default(cuid())
  name              String
  type              CommissionType
  appliesTo         String         @default("all") // "all" | vendor_id | category_id | product_id
  appliesToId       String?
  priority          Int            @default(0)
  rate              Decimal?       @db.Decimal(5, 4)
  tiers             Json?          // [{ from, to, rate }]
  includesTax       Boolean        @default(false)
  includesShipping  Boolean        @default(false)
  vendorId          String?        // null = global rule
  validFrom         DateTime
  validTo           DateTime?
  isActive          Boolean        @default(true)
  createdAt         DateTime       @default(now())

  vendor Vendor? @relation(fields: [vendorId], references: [id])

  @@index([vendorId])
  @@index([appliesTo, appliesToId])
  @@map("commission_rules")
}

enum SettlementStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  PAID
  DISPUTED
}

model Settlement {
  id                String           @id @default(cuid())
  vendorId          String
  periodFrom        DateTime
  periodTo          DateTime
  status            SettlementStatus @default(DRAFT)
  grossSales        Decimal          @db.Decimal(12, 2)
  commissionTotal   Decimal          @db.Decimal(12, 2)
  refundsDeducted   Decimal          @db.Decimal(12, 2) @default(0)
  adjustments       Decimal          @db.Decimal(12, 2) @default(0)
  adjustmentsNote   String?
  netPayable        Decimal          @db.Decimal(12, 2)
  paymentReference  String?
  approvedBy        String?
  approvedAt        DateTime?
  paidAt            DateTime?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  vendor Vendor           @relation(fields: [vendorId], references: [id])
  lines  SettlementLine[]

  @@index([vendorId])
  @@index([status])
  @@map("settlements")
}

model SettlementLine {
  id               String  @id @default(cuid())
  settlementId     String
  orderLineId      String
  orderId          String
  grossAmount      Decimal @db.Decimal(10, 2)
  commissionRate   Decimal @db.Decimal(5, 4)
  commissionAmount Decimal @db.Decimal(10, 2)
  netAmount        Decimal @db.Decimal(10, 2)

  settlement Settlement @relation(fields: [settlementId], references: [id], onDelete: Cascade)
  orderLine  OrderLine  @relation(fields: [orderLineId], references: [id])

  @@index([settlementId])
  @@map("settlement_lines")
}

// ─────────────────────────────────────────────────────────────────────────────
// INCIDENTS & RETURNS
// ─────────────────────────────────────────────────────────────────────────────

enum IncidentType {
  ITEM_NOT_RECEIVED
  ITEM_DAMAGED
  WRONG_ITEM
  ITEM_NOT_AS_DESCRIBED
  VENDOR_CANCELLED
  QUALITY_COMPLAINT
}

enum IncidentStatus {
  OPEN
  AWAITING_VENDOR
  AWAITING_CUSTOMER
  AWAITING_ADMIN
  RESOLVED
  CLOSED
}

enum IncidentResolution {
  REFUND_FULL
  REFUND_PARTIAL
  REPLACEMENT
  REJECTED
  GOODWILL_CREDIT
}

model Incident {
  id           String              @id @default(cuid())
  orderId      String
  orderLineId  String?
  vendorId     String
  customerId   String
  type         IncidentType
  status       IncidentStatus      @default(OPEN)
  resolution   IncidentResolution?
  slaDeadline  DateTime
  internalNote String?
  openedAt     DateTime            @default(now())
  resolvedAt   DateTime?
  closedAt     DateTime?
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt

  order     Order          @relation(fields: [orderId], references: [id])
  orderLine OrderLine?     @relation(fields: [orderLineId], references: [id])
  vendor    Vendor         @relation("VendorIncidents", fields: [vendorId], references: [id])
  customer  User           @relation("CustomerIncidents", fields: [customerId], references: [id])
  messages  IncidentMessage[]
  refunds   IncidentRefund[]

  @@index([orderId])
  @@index([vendorId])
  @@index([customerId])
  @@index([status])
  @@map("incidents")
}

model IncidentMessage {
  id          String   @id @default(cuid())
  incidentId  String
  senderType  String   // customer | vendor | admin | system
  senderId    String
  body        String   @db.Text
  attachments String[]
  isInternal  Boolean  @default(false) // solo visible por admins
  createdAt   DateTime @default(now())

  incident Incident @relation(fields: [incidentId], references: [id], onDelete: Cascade)

  @@index([incidentId])
  @@map("incident_messages")
}

model IncidentRefund {
  id            String   @id @default(cuid())
  incidentId    String
  amount        Decimal  @db.Decimal(10, 2)
  reason        String
  fundedBy      String   // vendor | marketplace | split
  paymentMethod String   // original | credit | bank
  processedBy   String?
  processedAt   DateTime?
  createdAt     DateTime @default(now())

  incident Incident @relation(fields: [incidentId], references: [id])

  @@index([incidentId])
  @@map("incident_refunds")
}
